APP_NAME="Celebrity Management Portal"
APP_ENV=production
APP_KEY=base64:BVQyT6oi4lOt+BM8Mcx0o3xPvfxyNOfit+Frsb3zr8c=
APP_DEBUG=false
APP_URL=https://managingteam.info

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── DATABASE (MySQL) ───
# UPDATE these with your cPanel MySQL credentials
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name
DB_USERNAME=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# ─── SESSION & CACHE (file = no DB queries, no terminal needed) ───
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.managingteam.info

CACHE_STORE=file

# ─── QUEUE (sync = emails send instantly, no queue worker needed) ───
QUEUE_CONNECTION=sync

# ─── BROADCASTING (skip if no Reverb) ───
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── MAIL (failover: auto-retries 587 → 465 → log) ───
# MAIL_MAILER should be 'failover'. Configure via admin: System → Mail Settings.
MAIL_MAILER=failover
MAIL_HOST=mail.managingteam.info
MAIL_PORT=587
MAIL_USERNAME=support@managingteam.info
MAIL_PASSWORD=changeme
MAIL_FROM_ADDRESS="support@managingteam.info"
MAIL_FROM_NAME="Celebrity Management Team"

# ─── AWS (optional) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
